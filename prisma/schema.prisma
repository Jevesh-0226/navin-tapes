generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Material {
  id        Int      @id @default(autoincrement())
  name      String   @unique

  purchases   Purchase[]
  stocks      Stock[]
  productions Production[]
}

model Purchase {
  id             Int      @id @default(autoincrement())
  date           DateTime
  invoice_no     String
  supplier       String
  
  // Either materialId OR size_mm must be provided
  materialId     Int?
  size_mm        Int?

  quantity_kg    Float
  quantity_box   Float?

  remarks        String?
  created_at     DateTime @default(now())

  material Material? @relation(fields: [materialId], references: [id])

  @@index([date])
  @@index([materialId])
  @@index([created_at])
}

model Production {
  id               Int      @id @default(autoincrement())
  date             DateTime
  operator_name    String
  materialId       Int
  size_mm          Int
  tapes            Int
  meters_per_tape  Float
  needle_break     Int      @default(0)
  total_production Float
  remark           String?
  created_at       DateTime @default(now())

  material Material @relation(fields: [materialId], references: [id])

  @@index([date])
  @@index([materialId])
  @@index([created_at])
}

model Sales {
  id             Int      @id @default(autoincrement())
  date           DateTime
  customer_name  String
  size_mm        Int

  quantity       Float
  rate           Float
  amount         Float

  remarks        String?
  created_at     DateTime @default(now())

  @@index([date])
  @@index([size_mm])
  @@index([created_at])
}

model Product {
  id          Int      @id @default(autoincrement())
  date        DateTime
  size_mm     Int

  quantity    Float    // finished tape produced (meters)

  remarks     String?
  created_at  DateTime @default(now())

  @@index([date])
  @@index([size_mm])
  @@index([created_at])
}

model Stock {
  id             Int      @id @default(autoincrement())
  date           DateTime

  // Raw material tracking
  materialId     Int?

  // Finished goods tracking
  size_mm        Int?

  opening_stock  Float     @default(0)
  purchase       Float     @default(0)
  production     Float     @default(0)
  sales          Float     @default(0)

  balance        Float

  material Material? @relation(fields: [materialId], references: [id])

  @@unique([date, materialId, size_mm])
  @@index([date])
  @@index([materialId])
  @@index([size_mm])
}
